# ─── App ───────────────────────────────────────
APP_NAME=Git Analytics Dashboard
APP_ENV=development
DEBUG=true

# ─── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/git_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=git_analytics

# ─── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ───────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ──────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Git ───────────────────────────────────────
CLONE_BASE_DIR=/tmp/git-analytics-repos

# ─── Pagination ────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
